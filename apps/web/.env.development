# Dev defaults for `npm run dev:web` (Vite loads this in development mode).
# API-first: the frontend fetches content from the local server (MongoDB-backed) first, then
# falls back to the IndexedDB cache / static public pack when the server is down. Start the
# backend with `npm run dev:server`. Not used in production builds.
VITE_API_BASE=http://localhost:4000/api/v1
