{
  "name": "ready-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "READY — The Travel Language Trainer. Deadline-driven language readiness app.",
  "workspaces": [
    "packages/*",
    "apps/*",
    "server"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "tsc -b && tsc --noEmit -p content/tsconfig.json && npm run typecheck -w @ready/web",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,css,html}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md,css,html}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "build": "tsc -b && npm run build:content && npm run build -w @ready/web",
    "build:content": "tsx content/build.ts",
    "validate:content": "tsx content/validate.ts",
    "smoke": "tsx scripts/smoke.ts",
    "gen:conversations": "tsx scripts/gen-conversations.ts",
    "verify": "npm run typecheck && npm run lint && npm run test && npm run build",
    "dev:web": "npm run dev -w @ready/web",
    "deploy": "npm run build && gh-pages -d apps/web/dist",
    "dev:server": "npm run dev -w @ready/server",
    "seed:all": "tsx server/src/seed/cli.ts all",
    "seed:words": "tsx server/src/seed/cli.ts words",
    "seed:phrases": "tsx server/src/seed/cli.ts phrases",
    "seed:situations": "tsx server/src/seed/cli.ts situations",
    "seed:content-packs": "tsx server/src/seed/cli.ts content-packs",
    "pipeline": "tsx content/pipeline/run.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.12.0",
    "@types/node": "^20.14.0",
    "@vitest/coverage-v8": "^2.1.2",
    "eslint": "^9.12.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "fake-indexeddb": "^6.0.0",
    "gh-pages": "^6.3.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.8.0",
    "vitest": "^2.1.2"
  },
  "dependencies": {
    "yaml": "^2.5.1"
  }
}
