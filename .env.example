# READY server environment — copy to .env and fill in.
PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/ready
# Generate with: openssl rand -hex 32
JWT_SECRET=
# From Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID (Web).
# See docs/RUNBOOK.md for the exact console steps.
GOOGLE_CLIENT_ID=
CORS_ORIGIN=http://localhost:5173
# Optional override; defaults to apps/web/public/content
# CONTENT_DIR=
# Client (Vite) — same Google client id, exposed to the browser:
VITE_GOOGLE_CLIENT_ID=
VITE_API_BASE=http://localhost:4000/api/v1
